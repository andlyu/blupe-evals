# Optional local overrides for scripts/start_so101_eval_stack.sh and
# scripts/stop_so101_eval_stack.sh.
#
# Copy this to config/so101_eval_stack.local.env when the Vast host changes.
# The .local.env file is intentionally not required; the launcher has current
# working defaults.

# Vast SSH target for the GPU box that runs MolmoAct2, SAM3, and the ball tracker.
SO101_GPU_HOST=ssh2.vast.ai
SO101_GPU_PORT=12394
SO101_GPU_USER=root
# SO101_GPU_SSH_KEY=/path/to/key

# Local stable ports.
SO101_POLICY_PORT=8202
SO101_SAM3_PORT=8213
SO101_SAM2_PORT=8214
SO101_CAMERA_RELAY_PORT=8089
SO101_WEB_PORT=8092
SO101_SAM3_VIDEO_MAX_SESSION_FRAMES=300

# Remote model/service defaults.
MOLMOACT2_CHECKPOINT_PATH=allenai/MolmoAct2-SO100_101
MOLMOACT2_NORM_TAG=so100_so101_molmoact2
MOLMOACT2_MODEL_DTYPE=float16
MOLMOACT2_NUM_FLOW_TIMESTEPS=10
SO101_SAM3_BACKEND=transformers
SO101_SAM3_MODEL_ID=facebook/sam3
# Use / for readiness because older deployed SAM3 service copies did not expose /health.
SO101_SAM3_READY_PATH=/
# SAM3 is gated on Hugging Face. By default the launcher copies the local token
# to the remote HF cache if the remote token is missing, without printing it.
SO101_SYNC_HF_TOKEN=1
# "Ready" means SAM3 can complete a real /api/detect_image request, not only
# that the root web UI is reachable.
SO101_SAM3_DETECT_TIMEOUT_S=240
SO101_SAM3_DETECT_REQUEST_TIMEOUT_S=90
# image is the low-latency SAM2 live tracker; video remains available for
# offline/quality SAM2 tests; sam3_video runs the SAM3 Video text tracker behind
# the same /api/track_image interface. yolo runs a trained YOLO segmentation
# model behind the same interface.
SO101_SAM2_TRACKER=image
SO101_SAM2_MODEL_ID=facebook/sam2.1-hiera-base-plus
# SO101_SAM2_TRACKER=sam3_video
# SO101_SAM2_PORT=8216
# SO101_SAM3_VIDEO_MODEL_ID=facebook/sam3
# SO101_SAM2_TRACKER=yolo
# SO101_YOLO_BALL_MODEL=/workspace/blupe-evals/runs/blue-ball-seg/weights/best.pt
# SO101_YOLO_BALL_IMGSZ=640
# SO101_YOLO_BALL_CONF=0.25

# Run scripts/check_so101_eval_stack.sh at the end of launch with UI and SAM3
# detect checks enabled. Set to 0 only for low-level debugging.
SO101_RUN_FINAL_CHECK=1

# Live success tracking. Cup/container detection and ball tracking use separate
# prompts; do not reuse the ball prompt for the cup/container mask.
SO101_SUCCESS_SAM3_PROMPT="black cylinder along with insides"
SO101_SUCCESS_SAM3_MIN_SCORE=0.25
SO101_SUCCESS_BALL_SAM3_PROMPT="light blue object"
SO101_SUCCESS_BALL_SAM3_MIN_SCORE=0.25
# The stack grounds the ball with SAM3 when no live ball mask exists and when
# the operator clicks Rerun SAM3. It does not periodically re-ground by default.
# The configured /api/track_image ball tracker refreshes the live mask every 2
# success-tracker frames, about 5 Hz at the default 10 Hz success loop. The UI
# status reports actual request latency, stream latency, inference Hz, and
# SAM2-vs-SAM3 alignment telemetry.
SO101_SUCCESS_BALL_SAM3_EVERY_N_FRAMES=0
SO101_SUCCESS_BALL_SAM2_EVERY_N_FRAMES=2

# Stop behavior.
SO101_STOP_REMOTE_SERVICES=1
# SO101_STOP_VAST_INSTANCE=1
# SO101_VAST_INSTANCE_ID=43132395
