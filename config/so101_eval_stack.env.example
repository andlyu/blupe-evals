# Optional local overrides for scripts/start_so101_eval_stack.sh and
# scripts/stop_so101_eval_stack.sh.
#
# Copy this to config/so101_eval_stack.local.env when the Vast host changes.
# The .local.env file is intentionally not required; the launcher has current
# working defaults.

# Vast SSH target for the GPU box that runs MolmoAct2, SAM3, and SAM2.
SO101_GPU_HOST=ssh2.vast.ai
SO101_GPU_PORT=12394
SO101_GPU_USER=root
# SO101_GPU_SSH_KEY=/path/to/key

# Local stable ports.
SO101_POLICY_PORT=8202
SO101_SAM3_PORT=8213
SO101_SAM2_PORT=8214
SO101_CAMERA_RELAY_PORT=8089
SO101_WEB_PORT=8092

# Remote model/service defaults.
MOLMOACT2_CHECKPOINT_PATH=allenai/MolmoAct2-SO100_101
MOLMOACT2_NORM_TAG=so100_so101_molmoact2
MOLMOACT2_MODEL_DTYPE=float16
MOLMOACT2_NUM_FLOW_TIMESTEPS=10
SO101_SAM3_BACKEND=transformers
# Use / for readiness because older deployed SAM3 service copies did not expose /health.
SO101_SAM3_READY_PATH=/
SO101_SAM2_MODEL_ID=facebook/sam2-hiera-tiny

# Stop behavior.
SO101_STOP_REMOTE_SERVICES=1
# SO101_STOP_VAST_INSTANCE=1
# SO101_VAST_INSTANCE_ID=43132395
