<mujoco model="yam">
  <compiler angle="radian" meshdir="assets"/>

  <!-- Stability + sim-teleop defaults (the vendored model is render-only):
       armature = reflected motor inertia, damping for well-behaved position control,
       and visual-only geoms so the folded home pose doesn't self-collide and jam joints. -->
  <default>
    <joint armature="0.1" damping="0.5"/>
    <geom contype="0" conaffinity="0"/>
  </default>

  <asset>
    <mesh name="base"  file="base.stl"/>
    <mesh name="link1" file="link1.stl"/>
    <mesh name="link2" file="link2.stl"/>
    <mesh name="link3" file="link3.stl"/>
    <mesh name="link4" file="link4.stl"/>
    <mesh name="link5" file="link5.stl"/>
  </asset>

  <worldbody>
    <geom pos="-0.0374966 -0.0464005 0.187501" quat="0.707105 0 0.707108 0" type="mesh" rgba="0.317647 0.121569 0.498039 1" mesh="base"/>
    <body name="link1" pos="0 0 0.067" quat="0.707105 0 0 -0.707108">
      <inertial pos="-0.00261782 0.00744082 0.0237251" quat="0.602276 0.365837 0.642523 0.300984" mass="0.104154" diaginertia="0.000139023 0.000109628 4.8478e-05"/>
      <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-2.61799 3.05433" actuatorfrcrange="-100 100"/>
      <geom pos="-0.0464 0.0374968 0.119501" quat="0.499998 0.5 0.5 -0.500002" type="mesh" rgba="0.72549 0.45098 0.317647 1" mesh="link1"/>
      <body name="link2" pos="-0.0329 0.02 0.0455" quat="0.499998 0.5 -0.500002 -0.5">
        <inertial pos="0.129165 0.000134495 -0.0321253" quat="0.499976 0.500008 0.500105 0.499911" mass="1.46908" diaginertia="0.0146686 0.014599 0.000800089"/>
        <joint name="joint2" pos="0 0 0" axis="0 0 1" range="0 3.65" actuatorfrcrange="-100 100"/>
        <geom pos="-0.0174977 -0.0740001 -0.07925" quat="0.499998 0.5 0.500002 0.5" type="mesh" rgba="0 0.4 0.6 1" mesh="link2"/>
        <body name="link3" pos="0.264 4.08431e-07 -0.06375" quat="9.38184e-07 -0.707105 -0.707108 9.38187e-07">
          <inertial pos="0.0556042 -0.135083 -0.0340514" quat="0.704407 0.697077 0.121918 -0.0550519" mass="0.982553" diaginertia="0.00765198 0.0076296 0.000876442"/>
          <joint name="joint3" pos="0 0 0" axis="0 0 1" range="0 3.66519" actuatorfrcrange="-100 100"/>
          <geom pos="0.0740003 -0.281499 -0.0813" quat="9.38184e-07 9.38187e-07 -0.707108 -0.707105" type="mesh" rgba="0.552941 0.580392 0.203922 1" mesh="link3"/>
          <body name="link4" pos="0.0600003 -0.244999 -0.00205" quat="1.32679e-06 0 0 -1">
            <inertial pos="-0.0543529 0.057068 -0.0332231" quat="0.636075 0.627088 0.370444 0.254833" mass="0.46678" diaginertia="0.000817855 0.000791274 0.000295776"/>
            <joint name="joint4" pos="0 0 0" axis="0 0 1" range="-1.5708 1.5708" actuatorfrcrange="-100 100"/>
            <geom pos="-0.0138003 0.0364989 -0.0787882" quat="0.707105 0.707108 0 0" type="mesh" rgba="0.545098 0.52549 0.419608 1" mesh="link4"/>
            <body name="link5" pos="-0.0403003 0.0703851 -0.0323887" quat="9.38184e-07 -0.707105 -9.38187e-07 -0.707108">
              <inertial pos="-3.55003e-05 -0.00717397 0.0375847" quat="0.911516 0.411243 -0.00302177 -0.00303654" mass="0.403307" diaginertia="0.000219794 0.000195686 0.000169647"/>
              <joint name="joint5" pos="0 0 0" axis="0 0 1" range="-1.5708 1.5708" actuatorfrcrange="-100 100"/>
              <geom pos="-0.0463995 0.0311519 0.0265" quat="0.499998 -0.5 -0.5 -0.500002" type="mesh" rgba="0.827451 0.623529 0.784314 1" mesh="link5"/>
              <!-- link6 pose + joint6 axis taken from i2rt's combined yam+linear_4310 model
                   (the standalone yam.xml link6 is a placeholder i2rt overrides via the gripper mount). -->
              <body name="link6" pos="2.39858e-07 -0.0419481 0.0404996" quat="0.499998 -0.5 -0.5 -0.500002">
                <inertial pos="0 0 0" mass="0.1" diaginertia="1e-4 1e-4 1e-4"/>
                <joint name="joint6" pos="0 0 0" axis="0 0 -1" range="-2.0944 2.0944" actuatorfrcrange="-100 100"/>
                <!-- EE/tool frame == i2rt grasp_site (linear_4310): +Z = gripper approach, 0.1347 m out.
                     This is the IK target (link_name="grasp"); gripper stub drawn along +Z. -->
                <body name="grasp" pos="0 0 -0.1347" quat="0 1 0 0">
                  <inertial pos="0 0 0" mass="0.01" diaginertia="1e-5 1e-5 1e-5"/>
                  <geom name="ee_palm" type="box" size="0.03 0.012 0.01" pos="0 0 -0.05" rgba="0.95 0.5 0.1 1"/>
                  <geom name="ee_finger_a" type="box" size="0.006 0.006 0.025" pos="0.025 0 -0.025" rgba="0.95 0.5 0.1 1"/>
                  <geom name="ee_finger_b" type="box" size="0.006 0.006 0.025" pos="-0.025 0 -0.025" rgba="0.95 0.5 0.1 1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Position actuators so the sim arm can be driven by the IK joint targets. -->
  <actuator>
    <position name="joint1" joint="joint1" kp="500" kv="15"/>
    <position name="joint2" joint="joint2" kp="500" kv="15"/>
    <position name="joint3" joint="joint3" kp="400" kv="13"/>
    <position name="joint4" joint="joint4" kp="150" kv="8"/>
    <position name="joint5" joint="joint5" kp="150" kv="8"/>
    <position name="joint6" joint="joint6" kp="100" kv="6"/>
  </actuator>

  <!-- Startup/home pose, captured from the REAL YAM (read_yam_home.py on can0, zero-torque
       encoder read). J3 clamped to its 0 lower limit. The controller resets here on launch
       and GO_HOME eases back to it. -->
  <keyframe>
    <key name="home" qpos="-0.02842 0.00134 0.0 -0.10014 -0.0555 -0.22717"
                     ctrl="-0.02842 0.00134 0.0 -0.10014 -0.0555 -0.22717"/>
  </keyframe>
</mujoco>
